# =============================================================
# Sanad — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# -------------------------------------------------------------
# Supabase (Required)
# Get from: https://supabase.com/dashboard → Settings → API
# -------------------------------------------------------------

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Your Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your Supabase service role key (SERVER-ONLY — never expose to client)
# Used for: admin operations, auth user creation, RLS bypass
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Your Supabase database password
# Get from: Supabase Dashboard → Settings → Database → Database Password
# Used for: running migrations via `npm run setup`
SUPABASE_DB_PASSWORD=your-database-password

# -------------------------------------------------------------
# Email — Resend (Required)
# Get from: https://resend.com/api-keys
# -------------------------------------------------------------

# Resend API key for transactional emails (welcome, invitations, fee reminders)
RESEND_API_KEY=your-resend-api-key

# -------------------------------------------------------------
# Application URL (Required)
# -------------------------------------------------------------

# The public URL of your application
# Production: https://sanadd.vercel.app (or your custom domain)
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------
# Payment Gateway — Rapid (Optional)
# Get from: https://rapidgateway.pk
# -------------------------------------------------------------

# Uncomment and fill in if using Rapid payment gateway
# RAPID_GATEWAY_API_KEY=your-rapid-gateway-api-key
# RAPID_GATEWAY_URL=https://api.rapidgateway.pk

# -------------------------------------------------------------
# Vercel (Auto-configured on Vercel platform)
# These are set automatically by Vercel — do NOT add to .env.local
# -------------------------------------------------------------

# VERCEL_ENV=production
# VERCEL_URL=sanadd.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=sanadd.vercel.app
